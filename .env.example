# 智谱 GLM key — natural-language constraint parsing.
# When unset, the app falls back to the built-in rule-based parser.
# Get a key at https://open.bigmodel.cn/  →  控制台 → API keys
ZHIPU_API_KEY=

# Optional: override the default model. Recommended values:
#   glm-4-flash   — free, very fast, good enough for constraint parsing (default)
#   glm-4-flashx  — slightly stronger, still very cheap
#   glm-4-air     — balanced
#   glm-4-plus    — strongest, use only if you also want LLM rationale generation
ZHIPU_MODEL=glm-4-flash

# Legacy: Perplexity key still works as a fallback for backwards compatibility.
# You only need ONE of ZHIPU_API_KEY or PERPLEXITY_API_KEY.
# PERPLEXITY_API_KEY=

# Amap (高德) Web Service key — server-side only, never exposed to the client.
# When unset, the planner uses the demo Shanghai city graph as before.
# When set, the /api/plan route enriches plans with Amap geocoding + route
# estimates and produces real navigation links.
# Apply at https://lbs.amap.com/  →  应用管理 → Web 服务 API
AMAP_API_KEY=your_amap_web_service_key
