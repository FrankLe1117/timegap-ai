{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "../.smoke-build",
    "rootDir": "..",
    "baseUrl": "..",
    "paths": { "@/*": ["src/*"] },
    "lib": ["ES2020", "DOM"]
  },
  "include": [
    "smoke-place-sanitize.ts",
    "../src/lib/place-sanitize.ts",
    "../src/lib/planner.ts",
    "../src/lib/planner-replace.ts",
    "../src/lib/amap-client.ts",
    "../src/lib/amap-enrich.ts",
    "../src/lib/candidate-pool.ts",
    "../src/lib/meituan-client.ts",
    "../src/lib/terminal-buffer.ts",
    "../src/lib/zh-time.ts",
    "../src/types/index.ts"
  ]
}
