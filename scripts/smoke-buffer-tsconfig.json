{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "../.smoke-build",
    "rootDir": "..",
    "baseUrl": "..",
    "paths": { "@/*": ["src/*"] },
    "lib": ["ES2020", "DOM"]
  },
  "include": [
    "smoke-buffer.ts",
    "../src/lib/zh-time.ts",
    "../src/lib/constraint-parser.ts",
    "../src/lib/planner.ts",
    "../src/lib/terminal-buffer.ts",
    "../src/lib/amap-client.ts",
    "../src/types/index.ts",
    "../src/data/shanghai_city_graph.json"
  ]
}
